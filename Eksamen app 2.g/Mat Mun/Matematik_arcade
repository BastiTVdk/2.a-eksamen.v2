    <!-- ==================== JAVASCRIPT MOTOR ==================== -->
    <script>
        // --- HJÆLPEFUNKTIONER ---
        function showScreen(id) {
            document.querySelectorAll('.screen').forEach(s => s.classList.remove('active'));
            document.getElementById(id).classList.add('active');
        }

        function drawCanvasGrid(ctx, w, h, scale, axisColor='rgba(255,255,255,0.4)', gridColor='rgba(255,255,255,0.05)') {
            ctx.clearRect(0, 0, w, h);
            ctx.beginPath(); 
            ctx.strokeStyle = gridColor; 
            ctx.lineWidth = 1;
            for(let x=0; x<=w; x+=scale) { ctx.moveTo(x, 0); ctx.lineTo(x, h); }
            for(let y=0; y<=h; y+=scale) { ctx.moveTo(0, y); ctx.lineTo(w, y); }
            ctx.stroke();
            
            ctx.beginPath(); 
            ctx.strokeStyle = axisColor; 
            ctx.lineWidth = 2;
            ctx.moveTo(w/2, 0); ctx.lineTo(w/2, h); 
            ctx.moveTo(0, h/2); ctx.lineTo(w, h/2);
            ctx.stroke();
        }

        function drawQuadratic(ctx, w, h, scale, a, b, c, color, isDashed=false, thickness=3) {
            ctx.beginPath();
            if(isDashed) ctx.setLineDash([10, 10]); else ctx.setLineDash([]);
            ctx.strokeStyle = color;
            ctx.lineWidth = thickness;
            ctx.shadowBlur = isDashed ? 0 : 15;
            ctx.shadowColor = color;
            for(let x = -20; x <= 20; x += 0.2) {
                let y = a*x*x + b*x + c;
                let cx = w/2 + x * scale;
                let cy = h/2 - y * scale;
                if(x === -20) ctx.moveTo(cx, cy);
                else ctx.lineTo(cx, cy);
            }
            ctx.stroke();
            ctx.setLineDash([]); ctx.shadowBlur = 0;
        }

        // --- GLOBAL TASTE-STYRING (Sikrer glidende multiplayer movement) ---
        const keys = {};
        window.addEventListener('keydown', e => { keys[e.key.toLowerCase()] = true; });
        window.addEventListener('keyup', e => { keys[e.key.toLowerCase()] = false; });


        // ============================================================================
        // SPIL 1: PARABEL HACKER
        // ============================================================================
        let hCtx, hW = 500, hH = 500, hScale = 25;
        let hTarget = {a: 1, b: 0, c: 0};
        let hTime = 60, hScore = 0, hLoopInt = null, hTimerInt = null;

        function startHackerGame() {
            hTime = 60; hScore = 0;
            document.getElementById('hack-score').innerText = hScore;
            hCtx = document.getElementById('hackCanvas').getContext('2d');
            
            // Nulstil sliders
            document.getElementById('hack-A').value = 1;
            document.getElementById('hack-B').value = 0;
            document.getElementById('hack-C').value = 0;
            
            showScreen('screen-hacker-game');
            if(hTimerInt) clearInterval(hTimerInt);
            if(hLoopInt) clearInterval(hLoopInt);

            // Timer loop
            hTimerInt = setInterval(() => {
                hTime -= 1;
                document.getElementById('hack-time').innerText = hTime;
                if(hTime <= 0) endHackerGameFinal();
            }, 1000);

            generateHackerTarget();
            hLoopInt = setInterval(updateHackerGraphics, 1000/60); // 60fps draw loop
        }

        function endHackerGameFinal() {
            clearInterval(hTimerInt); clearInterval(hLoopInt);
            document.getElementById('hack-final-score').innerText = hScore;
            showScreen('screen-hacker-end');
        }

        function endHackerGame() {
            clearInterval(hTimerInt); clearInterval(hLoopInt);
            showScreen('screen-menu');
        }

        function generateHackerTarget() {
            hTarget.a = [-2, -1, -0.5, 0.5, 1, 2][Math.floor(Math.random() * 6)];
            hTarget.b = Math.floor(Math.random() * 9) - 4; // -4 til 4
            hTarget.c = Math.floor(Math.random() * 13) - 6; // -6 til 6
            
            let statusEl = document.getElementById('hack-status');
            statusEl.innerText = "SØGER EFTER SIGNAL...";
            statusEl.style.color = "var(--neon-yellow)";
            statusEl.style.textShadow = "0 0 10px var(--neon-yellow)";
        }

        function updateHacker() {
            // Opdaterer kun text-værdier og formel når brugeren skruer
            let pA = parseFloat(document.getElementById('hack-A').value);
            let pB = parseFloat(document.getElementById('hack-B').value);
            let pC = parseFloat(document.getElementById('hack-C').value);

            document.getElementById('valH-A').innerText = pA.toFixed(1);
            document.getElementById('valH-B').innerText = pB.toFixed(1);
            document.getElementById('valH-C').innerText = pC.toFixed(1);
            
            let mathEl = document.getElementById('hack-formula');
            mathEl.innerHTML = `$f(x) = ${pA}x^2 ${pB>=0?'+':''} ${pB}x ${pC>=0?'+':''} ${pC}$`;
            MathJax.typesetPromise([mathEl]);
        }

        let hScanLine = -250; // Visuel radar effekt
        function updateHackerGraphics() {
            let pA = parseFloat(document.getElementById('hack-A').value);
            let pB = parseFloat(document.getElementById('hack-B').value);
            let pC = parseFloat(document.getElementById('hack-C').value);

            drawCanvasGrid(hCtx, hW, hH, hScale);
            
            // Radar scan effekt
            hScanLine += 5;
            if(hScanLine > hH) hScanLine = 0;
            hCtx.fillStyle = 'rgba(0, 243, 255, 0.05)';
            hCtx.fillRect(0, hScanLine, hW, 50);

            // Tegn fjende og spiller
            drawQuadratic(hCtx, hW, hH, hScale, hTarget.a, hTarget.b, hTarget.c, 'rgba(255,255,255,0.6)', true, 3);
            drawQuadratic(hCtx, hW, hH, hScale, pA, pB, pC, 'var(--neon-blue)', false, 4);

            // Tjek match
            if(Math.abs(pA - hTarget.a) < 0.1 && Math.abs(pB - hTarget.b) < 0.1 && Math.abs(pC - hTarget.c) < 0.1) {
                let statusEl = document.getElementById('hack-status');
                if(statusEl.innerText !== "HACK GENNEMFØRT!") {
                    statusEl.innerText = "HACK GENNEMFØRT!";
                    statusEl.style.color = "var(--neon-green)";
                    statusEl.style.textShadow = "0 0 15px var(--neon-green)";
                    
                    drawQuadratic(hCtx, hW, hH, hScale, pA, pB, pC, 'var(--neon-green)', false, 8);
                    
                    hScore++; hTime += 10;
                    document.getElementById('hack-score').innerText = hScore;
                    document.getElementById('hack-time').innerText = hTime;
                    
                    setTimeout(generateHackerTarget, 1000);
                }
            }
        }


        // ============================================================================
        // SPIL 2: SHAPE SHIFTER DUEL
        // ============================================================================
        let dCtx1, dCtx2;
        let dTarget = {a: 1, c: 0};
        let p1 = {a: -1, c: 5}, p2 = {a: -1, c: 5};
        let dScore1 = 0, dScore2 = 0;
        let dActive = false;

        function startDuelGame() {
            dScore1 = 0; dScore2 = 0;
            updateDuelHUD();
            dCtx1 = document.getElementById('duelCanvas1').getContext('2d');
            dCtx2 = document.getElementById('duelCanvas2').getContext('2d');
            document.getElementById('duel-winner-overlay').style.display = 'none';
            showScreen('screen-duel-game');
            dActive = true;
            generateDuelTarget();
            requestAnimationFrame(duelLoop);
        }

        function endDuelGame() { dActive = false; showScreen('screen-menu'); }

        function generateDuelTarget() {
            dTarget.a = [-2, -1, -0.5, 0.5, 1, 2][Math.floor(Math.random() * 6)];
            dTarget.c = Math.floor(Math.random() * 11) - 5;
            p1.a = 1; p1.c = 0; 
            p2.a = 1; p2.c = 0;
            updateDuelHUD();
        }

        function updateDuelHUD() {
            document.getElementById('d-score-1').innerText = dScore1;
            document.getElementById('d-score-2').innerText = dScore2;
            document.getElementById('d1-a').innerText = p1.a.toFixed(1);
            document.getElementById('d1-c').innerText = p1.c.toFixed(1);
            document.getElementById('d2-a').innerText = p2.a.toFixed(1);
            document.getElementById('d2-c').innerText = p2.c.toFixed(1);
        }

        function duelLoop() {
            if(!dActive) return;

            // Player 1 Input (W/S for 'a', A/D for 'c')
            if(keys['w'] && p1.a < 3) p1.a += 0.05;
            if(keys['s'] && p1.a > -3) p1.a -= 0.05;
            if(Math.abs(p1.a) < 0.1) p1.a = 0.2; // Undgå 0
            if(keys['a'] && p1.c > -8) p1.c -= 0.2;
            if(keys['d'] && p1.c < 8) p1.c += 0.2;

            // Player 2 Input (Arrows)
            if(keys['arrowup'] && p2.a < 3) p2.a += 0.05;
            if(keys['arrowdown'] && p2.a > -3) p2.a -= 0.05;
            if(Math.abs(p2.a) < 0.1) p2.a = 0.2;
            if(keys['arrowleft'] && p2.c > -8) p2.c -= 0.2;
            if(keys['arrowright'] && p2.c < 8) p2.c += 0.2;

            updateDuelHUD();

            // Tegn Spiller 1
            drawCanvasGrid(dCtx1, 400, 400, 20);
            drawQuadratic(dCtx1, 400, 400, 20, dTarget.a, 0, dTarget.c, 'rgba(255,255,255,0.7)', true, 3);
            drawQuadratic(dCtx1, 400, 400, 20, p1.a, 0, p1.c, 'var(--neon-blue)', false, 4);

            // Tegn Spiller 2
            drawCanvasGrid(dCtx2, 400, 400, 20);
            drawQuadratic(dCtx2, 400, 400, 20, dTarget.a, 0, dTarget.c, 'rgba(255,255,255,0.7)', true, 3);
            drawQuadratic(dCtx2, 400, 400, 20, p2.a, 0, p2.c, 'var(--neon-pink)', false, 4);

            // Win Condition Tjek (Tolerancen er 0.15)
            let p1Win = Math.abs(p1.a - dTarget.a) < 0.15 && Math.abs(p1.c - dTarget.c) < 0.5;
            let p2Win = Math.abs(p2.a - dTarget.a) < 0.15 && Math.abs(p2.c - dTarget.c) < 0.5;

            if(p1Win || p2Win) {
                dActive = false; // Lås input
                if(p1Win) {
                    dScore1++; drawQuadratic(dCtx1, 400, 400, 20, p1.a, 0, p1.c, 'var(--neon-green)', false, 8);
                } else {
                    dScore2++; drawQuadratic(dCtx2, 400, 400, 20, p2.a, 0, p2.c, 'var(--neon-green)', false, 8);
                }
                
                updateDuelHUD();

                if(dScore1 >= 5 || dScore2 >= 5) {
                    setTimeout(() => {
                        document.getElementById('duel-winner-overlay').style.display = 'flex';
                        let wText = document.getElementById('duel-winner-text');
                        wText.innerText = dScore1 >= 5 ? "BLÅ VINDER!" : "PINK VINDER!";
                        wText.style.color = dScore1 >= 5 ? "var(--neon-blue)" : "var(--neon-pink)";
                        wText.style.textShadow = dScore1 >= 5 ? "0 0 30px var(--neon-blue)" : "0 0 30px var(--neon-pink)";
                    }, 1000);
                } else {
                    setTimeout(() => { dActive = true; generateDuelTarget(); }, 1500);
                }
            }

            if(dActive) requestAnimationFrame(duelLoop);
        }


        // ============================================================================
        // SPIL 3: LASER SKJOLDET
        // ============================================================================
        let lCtx, lCanvas;
        let lLine = {a: 1, b: 0}, lTargetDist = 0, lRound = 1;

        function startLaserGame() { 
            lRound = 1;
            lCanvas = document.getElementById('laserCanvas'); 
            lCtx = lCanvas.getContext('2d'); 
            showScreen('screen-laser-game'); 
            generateLaserRound(); 
        }

        function generateLaserRound() {
            document.getElementById('laser-round').innerText = lRound;
            document.getElementById('laser-feedback').style.display = 'none';
            
            lLine.a = [-2, -1, -0.5, 0.5, 1, 2][Math.floor(Math.random() * 6)];
            lLine.b = Math.floor(Math.random() * 9) - 4;
            lTargetDist = (Math.floor(Math.random() * 4) + 2); // 2 til 5
            
            let mathEq = document.getElementById('laser-eq');
            mathEq.innerHTML = `$y = ${lLine.a}x ${lLine.b>=0?'+':''} ${lLine.b}$`;
            MathJax.typesetPromise([mathEq]);

            document.getElementById('laser-target').innerText = lTargetDist.toFixed(1);
            
            drawLaserField();
        }

        function drawLaserField(shieldP = null, hit = false) {
            drawCanvasGrid(lCtx, 600, 500, 25);
            
            // Tegn Laseren
            lCtx.beginPath();
            lCtx.strokeStyle = 'var(--neon-red)';
            lCtx.lineWidth = 4;
            lCtx.shadowBlur = 15; lCtx.shadowColor = 'var(--neon-red)';
            let x1 = -15, y1 = lLine.a*x1 + lLine.b;
            let x2 = 15, y2 = lLine.a*x2 + lLine.b;
            lCtx.moveTo(300 + x1*25, 250 - y1*25);
            lCtx.lineTo(300 + x2*25, 250 - y2*25);
            lCtx.stroke();
            lCtx.shadowBlur = 0;

            if(shieldP) {
                // Tegn Shield
                lCtx.beginPath();
                lCtx.arc(300 + shieldP.x*25, 250 - shieldP.y*25, 8, 0, Math.PI*2);
                lCtx.fillStyle = hit ? 'var(--neon-green)' : 'white';
                lCtx.fill();
                lCtx.shadowBlur = 20; lCtx.shadowColor = hit ? 'var(--neon-green)' : 'white';
                lCtx.stroke();
                lCtx.shadowBlur = 0;

                // Tegn afstandslinje
                let a_perp = lLine.a === 0 ? 1000 : -1 / lLine.a;
                let b_perp = shieldP.y - a_perp * shieldP.x;
                let projX = (b_perp - lLine.b) / (lLine.a - a_perp);
                let projY = lLine.a * projX + lLine.b;

                lCtx.beginPath();
                lCtx.setLineDash([5, 5]);
                lCtx.strokeStyle = hit ? 'var(--neon-green)' : 'rgba(255,255,255,0.7)';
                lCtx.lineWidth = 2;
                lCtx.moveTo(300 + shieldP.x*25, 250 - shieldP.y*25);
                lCtx.lineTo(300 + projX*25, 250 - projY*25);
                lCtx.stroke();
                lCtx.setLineDash([]);
            }
        }

        // Klik for at placere skjold
        document.getElementById('laserCanvas').addEventListener('mousedown', function(e) {
            if(document.getElementById('laser-feedback').style.display === 'block') return;

            const rect = lCanvas.getBoundingClientRect();
            let mathX = (e.clientX - rect.left - 300) / 25; 
            let mathY = (250 - (e.clientY - rect.top)) / 25;
            
            // Dist = |ax - y + b| / sqrt(a^2 + 1)
            let d = Math.abs(lLine.a * mathX - mathY + lLine.b) / Math.sqrt(lLine.a*lLine.a + 1);
            let isHit = Math.abs(d - lTargetDist) < 0.4;
            
            drawLaserField({x: mathX, y: mathY}, isHit);
            
            let fb = document.getElementById('laser-feedback');
            if(isHit) {
                fb.innerText = `KORREKT! Afstand = ${d.toFixed(1)}`;
                fb.style.color = "var(--neon-green)";
                fb.style.textShadow = "0 0 20px black, 0 0 10px var(--neon-green)";
                fb.style.display = "block";
                setTimeout(() => { lRound++; generateLaserRound(); }, 2000);
            } else {
                fb.innerText = `FEJL! Din afstand = ${d.toFixed(1)}`;
                fb.style.color = "var(--neon-red)";
                fb.style.textShadow = "0 0 20px black, 0 0 10px var(--neon-red)";
                fb.style.display = "block";
                setTimeout(() => { fb.style.display = "none"; drawLaserField(); }, 1500);
            }
        });


        // ============================================================================
        // SPIL 4: TANGENT SNIPER (Differentialregning)
        // ============================================================================
        let tCanvas, tCtx;
        let tScore1 = 0, tScore2 = 0;
        let tank1 = { x: -8, y: 0, color: 'var(--neon-blue)' };
        let tank2 = { x: 8, y: 0, color: 'var(--neon-pink)' };
        let projectiles = []; // Array of {x, y, dx, dy, color, shooterNum}
        let tActive = false;
        let tScale = 30;
        
        // Landskabs typer
        const landscapes = [
            { name: "Sinus Bølgen", f: (x) => 4 * Math.sin(x/2.5), df: (x) => (4/2.5) * Math.cos(x/2.5) },
            { name: "Parabel Dalen", f: (x) => 0.1*x*x - 3, df: (x) => 0.2*x },
            { name: "Det Skæve Bjerg", f: (x) => Math.sin(x) + Math.cos(x/2)*2, df: (x) => Math.cos(x) - Math.sin(x/2) }
        ];
        let currentLevel = 0;

        function startTangentGame() {
            tScore1 = 0; tScore2 = 0;
            currentLevel = 0;
            projectiles = [];
            document.getElementById('t-score-1').innerText = tScore1;
            document.getElementById('t-score-2').innerText = tScore2;
            document.getElementById('tangent-winner-overlay').style.display = 'none';
            tCanvas = document.getElementById('tangentCanvas');
            tCtx = tCanvas.getContext('2d');
            showScreen('screen-tangent-game');
            spawnTanks();
            tActive = true;
            requestAnimationFrame(tangentLoop);
        }

        function endTangentGame() { tActive = false; showScreen('screen-menu'); }

        function spawnTanks() {
            document.getElementById('t-landscape-name').innerText = landscapes[currentLevel].name;
            tank1.x = -8 - Math.random()*2;
            tank2.x = 8 + Math.random()*2;
        }

        function tangentLoop() {
            if(!tActive) return;
            const w = tCanvas.width, h = tCanvas.height;
            let level = landscapes[currentLevel];
            
            // Input
            if(keys['a'] && tank1.x > -15) tank1.x -= 0.1;
            if(keys['d'] && tank1.x < -1) tank1.x += 0.1;
            if(keys['arrowleft'] && tank2.x > 1) tank2.x -= 0.1;
            if(keys['arrowright'] && tank2.x < 15) tank2.x += 0.1;
            
            // Update y positions
            tank1.y = level.f(tank1.x);
            tank2.y = level.f(tank2.x);

            // Draw Background
            drawCanvasGrid(tCtx, w, h, tScale);
            
            // Draw Landscape f(x)
            tCtx.beginPath();
            tCtx.strokeStyle = 'rgba(255,255,255,0.8)';
            tCtx.lineWidth = 4;
            for(let px = 0; px <= w; px++) {
                let mX = (px - w/2) / tScale;
                let py = h/2 - level.f(mX) * tScale;
                if(px===0) tCtx.moveTo(px, py); else tCtx.lineTo(px, py);
            }
            tCtx.stroke();

            // Draw Tanks and their Tangent Lines
            drawTankWithTangent(tank1, w, h, level, 1);
            drawTankWithTangent(tank2, w, h, level, 2);

            // Opdater Projectiles
            for(let i = projectiles.length - 1; i >= 0; i--) {
                let p = projectiles[i];
                p.x += p.dx; p.y += p.dy;
                
                // Draw Projectile
                let px = w/2 + p.x*tScale; let py = h/2 - p.y*tScale;
                tCtx.beginPath(); tCtx.arc(px, py, 6, 0, Math.PI*2);
                tCtx.fillStyle = 'white'; tCtx.fill();
                tCtx.shadowBlur = 15; tCtx.shadowColor = p.color;
                tCtx.stroke(); tCtx.shadowBlur = 0;

                // Hit Detection
                let target = p.shooterNum === 1 ? tank2 : tank1;
                let dist = Math.sqrt(Math.pow(p.x - target.x, 2) + Math.pow(p.y - target.y, 2));
                if(dist < 0.6) { // Hit!
                    if(p.shooterNum === 1) tScore1++; else tScore2++;
                    document.getElementById('t-score-1').innerText = tScore1;
                    document.getElementById('t-score-2').innerText = tScore2;
                    projectiles.splice(i, 1); // Fjern skud
                    
                    // Næste level
                    currentLevel = (currentLevel + 1) % landscapes.length;
                    spawnTanks();

                    if(tScore1 >= 5 || tScore2 >= 5) {
                        tActive = false;
                        document.getElementById('tangent-winner-overlay').style.display = 'flex';
                        let wTxt = document.getElementById('tangent-winner-text');
                        wTxt.innerText = tScore1 >= 5 ? "BLÅ VINDER!" : "PINK VINDER!";
                        wTxt.style.color = tScore1 >= 5 ? "var(--neon-blue)" : "var(--neon-pink)";
                    }
                    continue;
                }

                // Fjern hvis ude af skærm
                if(p.x < -20 || p.x > 20 || p.y < -20 || p.y > 20) {
                    projectiles.splice(i, 1);
                }
            }

            requestAnimationFrame(tangentLoop);
        }

        function drawTankWithTangent(tank, w, h, level, playerNum) {
            let px = w/2 + tank.x * tScale;
            let py = h/2 - tank.y * tScale;
            let slope = level.df(tank.x);
            
            // HUD Opdatering
            let b_val = tank.y - slope * tank.x;
            let eqStr = `y = ${slope.toFixed(2)}x ${b_val>=0?'+':''} ${b_val.toFixed(2)}`;
            document.getElementById(`t-eq-${playerNum}`).innerText = eqStr;

            // Tegn Tangent Linje (Sigtekorn)
            tCtx.beginPath(); 
            tCtx.strokeStyle = tank.color; 
            tCtx.setLineDash([5, 10]); 
            tCtx.lineWidth = 2;
            let x1 = -20, y1 = slope * (x1 - tank.x) + tank.y;
            let x2 = 20, y2 = slope * (x2 - tank.x) + tank.y;
            tCtx.moveTo(w/2 + x1*tScale, h/2 - y1*tScale); 
            tCtx.lineTo(w/2 + x2*tScale, h/2 - y2*tScale);
            tCtx.stroke(); 
            tCtx.setLineDash([]);

            // Tegn Tank (firkant for at se sejere ud)
            tCtx.fillStyle = tank.color;
            tCtx.shadowBlur = 20; tCtx.shadowColor = tank.color;
            // Beregn rotation ud fra tangent hældning
            let angle = Math.atan(-slope); // -slope fordi canvas y er omvendt
            tCtx.save();
            tCtx.translate(px, py);
            tCtx.rotate(angle);
            tCtx.fillRect(-15, -10, 30, 20); // Tank krop
            tCtx.fillRect(10, -3, 15, 6); // Kanonrør
            tCtx.restore();
            tCtx.shadowBlur = 0;
        }

        // Skyde Logik med cooldowns
        let canShoot1 = true, canShoot2 = true;
        window.addEventListener('keydown', (e) => {
            if(!tActive) return;
            const key = e.key.toLowerCase();
            if(key === 'w' && canShoot1) {
                shootProjectile(tank1, 1);
                canShoot1 = false; setTimeout(() => canShoot1=true, 1000);
            }
            if(key === 'arrowup' && canShoot2) {
                shootProjectile(tank2, 2);
                canShoot2 = false; setTimeout(() => canShoot2=true, 1000);
            }
        });

        function shootProjectile(shooter, num) {
            let slope = landscapes[currentLevel].df(shooter.x);
            // Normaliser retningsvektoren (dx, dy)
            let length = Math.sqrt(1 + slope*slope);
            let dir = num === 1 ? 1 : -1; // P1 skyder mod højre, P2 mod venstre
            let speed = 0.5; // Fart på projektilet

            projectiles.push({
                x: shooter.x,
                y: shooter.y,
                dx: (dir / length) * speed,
                dy: (dir * slope / length) * speed,
                color: shooter.color,
                shooterNum: num
            });
        }


        // ============================================================================
        // SPIL 5: VIRUS OUTBREAK (Eksponentiel Vækst)
        // ============================================================================
        let vCanvas, vCtx;
        let vActive = false;
        let vData = { b: 5, a: 1.15 }; // Fjendens parametre
        let vTime = 0, vScore = 0;
        let vCureProgress = 0;

        function startVirusGame() {
            vCanvas = document.getElementById('virusCanvas');
            vCtx = vCanvas.getContext('2d');
            vScore = 0; document.getElementById('v-score').innerText = vScore;
            
            // Reset Sliders
            document.getElementById('virus-b').value = 1;
            document.getElementById('virus-a').value = 1.01;
            
            showScreen('screen-virus-game');
            spawnVirus();
            vActive = true;
            requestAnimationFrame(virusLoop);
        }

        function endVirusGame() { vActive = false; showScreen('screen-menu'); }

        function spawnVirus() {
            vTime = 0;
            vCureProgress = 0;
            // Generer Virus Math
            vData.b = Math.floor(Math.random() * 8) + 2; // 2 til 9
            vData.a = [1.10, 1.15, 1.20, 1.25, 1.30, 1.35][Math.floor(Math.random() * 6)];
            
            // INTEL REPORT
            let y0 = vData.b;
            let y5 = vData.b * Math.pow(vData.a, 5);
            document.getElementById('v-intel-1').innerText = `Målt Y til tiden X=0: ${y0}`;
            document.getElementById('v-intel-2').innerText = `Målt Y til tiden X=5: ${y5.toFixed(1)}`;
            
            updateVirusControls(); // Reset display
        }

        function updateVirusControls() {
            let pB = document.getElementById('virus-b').value;
            let pA = document.getElementById('virus-a').value;
            document.getElementById('v-b-display').innerText = pB;
            document.getElementById('v-a-display').innerText = pA;
        }

        function virusLoop() {
            if(!vActive) return;
            vTime += 0.015; // Virussen vokser konstant
            
            const w = vCanvas.width, h = vCanvas.height;
            const scaleX = w / 15; // Tid = 15 dage
            const scaleY = h / 100; // Max smittede = 100

            vCtx.clearRect(0, 0, w, h);
            
            // Grid
            vCtx.strokeStyle = 'rgba(255,255,255,0.05)'; vCtx.lineWidth = 1;
            for(let i=0; i<w; i+=scaleX) { vCtx.moveTo(i, 0); vCtx.lineTo(i, h); }
            for(let i=0; i<h; i+=scaleY*10) { vCtx.moveTo(0, i); vCtx.lineTo(w, i); }
            vCtx.stroke();

            // Tegn VIRUS (Rød) kun op til vTime
            vCtx.beginPath();
            vCtx.strokeStyle = 'var(--neon-red)';
            vCtx.lineWidth = 4;
            vCtx.shadowBlur = 15; vCtx.shadowColor = 'var(--neon-red)';
            for(let x=0; x<=vTime; x+=0.1) {
                let y = vData.b * Math.pow(vData.a, x);
                if(x===0) vCtx.moveTo(x*scaleX, h - y*scaleY); else vCtx.lineTo(x*scaleX, h - y*scaleY);
            }
            vCtx.stroke(); vCtx.shadowBlur = 0;

            // Tegn SPILLERENS KUR (Grøn)
            let pB = parseFloat(document.getElementById('virus-b').value);
            let pA = parseFloat(document.getElementById('virus-a').value);
            
            vCtx.beginPath();
            vCtx.strokeStyle = 'var(--neon-green)';
            vCtx.setLineDash([5, 10]);
            vCtx.lineWidth = 2;
            for(let x=0; x<=15; x+=0.2) {
                let y = pB * Math.pow(pA, x);
                if(x===0) vCtx.moveTo(x*scaleX, h - y*scaleY); else vCtx.lineTo(x*scaleX, h - y*scaleY);
            }
            vCtx.stroke(); vCtx.setLineDash([]);

            // FARE NIVEAU
            let currentVirusVal = vData.b * Math.pow(vData.a, vTime);
            let dangerEl = document.getElementById('v-danger');
            if(currentVirusVal > 80) { dangerEl.innerText = "KRITISK"; dangerEl.style.background = "rgba(255,7,58,0.8)"; }
            else if(currentVirusVal > 50) { dangerEl.innerText = "HØJ"; dangerEl.style.background = "rgba(255,140,0,0.5)"; }
            else { dangerEl.innerText = "LAV"; dangerEl.style.background = "rgba(255,7,58,0.2)"; }

            // GAME OVER?
            if(currentVirusVal >= 100) {
                alert(`INFEKTION TOTAL! Du fejlede. Virussens formel var f(x) = ${vData.b} * ${vData.a}^x`);
                spawnVirus();
            }

            // SYNTETISERING (Match Logic)
            if(pB === vData.b && Math.abs(pA - vData.a) < 0.01) {
                vCureProgress += 1; // Fylder baren
                document.getElementById('v-cure-progress').style.width = vCureProgress + '%';
                
                if(vCureProgress >= 100) {
                    vScore++; document.getElementById('v-score').innerText = vScore;
                    vCtx.fillStyle = 'rgba(57, 255, 20, 0.4)'; vCtx.fillRect(0,0,w,h); // Grønt flash
                    setTimeout(spawnVirus, 1000);
                }
            } else {
                vCureProgress = 0; // Taber progress hvis man justerer forkert
                document.getElementById('v-cure-progress').style.width = '0%';
            }

            requestAnimationFrame(virusLoop);
        }

    </script>
</body>
</html>
