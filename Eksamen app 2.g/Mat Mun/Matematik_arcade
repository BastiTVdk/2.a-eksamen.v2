                    <div id="v-cure-progress" style="height: 100%; width: 0%; background: var(--neon-green); transition: width 0.1s linear; box-shadow: 0 0 10px var(--neon-green);"></div>
                </div>
                <div style="text-align: center; font-size: 0.8rem; color: var(--text-muted); margin-top: 5px;">SYNTETISERER KUR...</div>
            </div>
