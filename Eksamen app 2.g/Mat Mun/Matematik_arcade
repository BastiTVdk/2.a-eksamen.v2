<!DOCTYPE html>
<html lang="da">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>MatheMaster ARCADE | B-Niveau Eksamenstræning</title>
    
    <!-- MathJax til at rendre flotte matematiske formler -->
    <script>
        MathJax = {
            tex: { inlineMath: [['$', '$'], ['\\(', '\\)']] },
            svg: { fontCache: 'global' }
        };
    </script>
    <script id="MathJax-script" async src="https://cdn.jsdelivr.net/npm/mathjax@3/es5/tex-mml-chtml.js"></script>
    
    <style>
        /* Importerer Arcade-fonte fra Google Fonts */
        @import url('https://fonts.googleapis.com/css2?family=Orbitron:wght@400;700;900&family=Poppins:wght@400;600;800&display=swap');

        :root {
            /* Neon Farvepalette */
            --bg-base: #050510;
            --neon-blue: #00f3ff;
            --neon-pink: #ff00ea;
            --neon-green: #39ff14;
            --neon-yellow: #fffb00;
            --neon-red: #ff073a;
            --neon-purple: #b026ff;
            --neon-orange: #ff8c00;
            --panel-bg: rgba(20, 20, 40, 0.85);
            --font-game: 'Orbitron', sans-serif;
            --font-ui: 'Poppins', sans-serif;
        }

        /* --- GLOBALE RESET OG BASIS --- */
        * { box-sizing: border-box; margin: 0; padding: 0; }
        
        body {
            font-family: var(--font-ui);
            background-color: var(--bg-base);
            /* Subtil grid-baggrund kombineret med radial gradients */
            background-image: 
                linear-gradient(rgba(0, 243, 255, 0.03) 1px, transparent 1px),
                linear-gradient(90deg, rgba(0, 243, 255, 0.03) 1px, transparent 1px),
                radial-gradient(circle at 15% 50%, rgba(0, 243, 255, 0.08), transparent 25%),
                radial-gradient(circle at 85% 30%, rgba(255, 0, 234, 0.08), transparent 25%);
            background-size: 50px 50px, 50px 50px, 100% 100%, 100% 100%;
            color: white;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            overflow-x: hidden;
            user-select: none; /* Forhindrer at man markerer tekst under spil */
        }

        /* Skjuler scrollebar for et renere arcade look */
        ::-webkit-scrollbar { width: 8px; }
        ::-webkit-scrollbar-track { background: var(--bg-base); }
        ::-webkit-scrollbar-thumb { background: #334155; border-radius: 4px; }

        /* --- SKÆRMSTYRING --- */
        .screen { 
            display: none; 
            flex-direction: column; 
            align-items: center; 
            justify-content: center; 
            min-height: 100vh; 
            width: 100vw; 
            padding: 2rem; 
            position: absolute; 
            top: 0; 
            left: 0; 
        }
        .screen.active { 
            display: flex; 
            animation: popIn 0.5s cubic-bezier(0.175, 0.885, 0.32, 1.275); 
        }
        
        @keyframes popIn { 
            from { opacity: 0; transform: scale(0.95) translateY(20px); } 
            to { opacity: 1; transform: scale(1) translateY(0); } 
        }
        
        /* --- TYPOGRAFI OG UI ELEMENTER --- */
        .title-glow {
            font-family: var(--font-game); 
            font-size: 4.5rem; 
            font-weight: 900; 
            text-align: center; 
            margin-bottom: 2rem;
            color: #fff; 
            text-shadow: 
                0 0 10px #fff, 
                0 0 20px var(--neon-blue), 
                0 0 40px var(--neon-blue), 
                0 0 80px var(--neon-pink);
            letter-spacing: 5px; 
            text-transform: uppercase;
        }

        .subtitle {
            font-size: 1.2rem;
            color: #94a3b8;
            max-width: 600px;
            text-align: center;
            margin-bottom: 2rem;
            line-height: 1.6;
        }

        /* Neon Knapper */
        .btn-neon {
            background: rgba(0,0,0,0.5); 
            color: white; 
            font-family: var(--font-game); 
            font-size: 1.2rem; 
            font-weight: 700;
            padding: 1rem 2.5rem; 
            border: 2px solid; 
            border-radius: 12px; 
            cursor: pointer; 
            transition: all 0.3s; 
            text-transform: uppercase; 
            letter-spacing: 2px;
            box-shadow: 0 0 15px inset, 0 0 15px;
        }
        .btn-neon:hover {
            transform: scale(1.05);
            color: black;
        }
        .btn-neon:active { transform: scale(0.95); }
        
        .btn-blue { border-color: var(--neon-blue); box-shadow: 0 0 15px rgba(0, 243, 255, 0.3) inset, 0 0 15px rgba(0, 243, 255, 0.3); }
        .btn-blue:hover { background: var(--neon-blue); box-shadow: 0 0 30px var(--neon-blue); }
        
        .btn-pink { border-color: var(--neon-pink); box-shadow: 0 0 15px rgba(255, 0, 234, 0.3) inset, 0 0 15px rgba(255, 0, 234, 0.3); }
        .btn-pink:hover { background: var(--neon-pink); box-shadow: 0 0 30px var(--neon-pink); }
        
        .btn-green { border-color: var(--neon-green); box-shadow: 0 0 15px rgba(57, 255, 20, 0.3) inset, 0 0 15px rgba(57, 255, 20, 0.3); }
        .btn-green:hover { background: var(--neon-green); box-shadow: 0 0 30px var(--neon-green); }
        
        .btn-orange { border-color: var(--neon-orange); box-shadow: 0 0 15px rgba(255, 140, 0, 0.3) inset, 0 0 15px rgba(255, 140, 0, 0.3); }
        .btn-orange:hover { background: var(--neon-orange); box-shadow: 0 0 30px var(--neon-orange); }

        .back-btn { 
            position: absolute; 
            top: 20px; 
            left: 20px; 
            background: rgba(255,255,255,0.05); 
            color: white; 
            border: 1px solid rgba(255,255,255,0.2); 
            padding: 10px 20px; 
            border-radius: 8px; 
            cursor: pointer; 
            transition: 0.2s; 
            font-family: var(--font-ui); 
            font-weight: 600;
            z-index: 1000; 
            text-decoration: none;
        }
        .back-btn:hover { background: rgba(255,255,255,0.2); border-color: white; }

        /* Canvas indstillinger */
        canvas { 
            background: rgba(0,0,0,0.8); 
            border: 2px solid rgba(255,255,255,0.1); 
            border-radius: 15px; 
            box-shadow: inset 0 0 50px rgba(0,0,0,1), 0 0 20px rgba(0,0,0,0.5); 
        }

        /* --- MENU KORT --- */
        .mode-cards { 
            display: flex; 
            gap: 2rem; 
            justify-content: center; 
            flex-wrap: wrap; 
            margin-top: 2rem; 
            max-width: 1300px; 
        }
        .card { 
            background: var(--panel-bg); 
            border: 2px solid; 
            border-radius: 20px; 
            padding: 2.5rem; 
            width: 320px; 
            text-align: center; 
            cursor: pointer; 
            transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275); 
            backdrop-filter: blur(10px); 
            display: flex; 
            flex-direction: column; 
            justify-content: flex-start; 
        }
        .card:hover { transform: translateY(-15px) scale(1.02); }
        .card-icon { font-size: 3.5rem; margin-bottom: 1rem; filter: drop-shadow(0 0 10px rgba(255,255,255,0.5)); }
        
        .card-solo { border-color: var(--neon-blue); box-shadow: 0 0 15px rgba(0, 243, 255, 0.1); }
        .card-solo:hover { box-shadow: 0 15px 30px rgba(0, 243, 255, 0.4); }
        .card-solo h2 { color: var(--neon-blue); font-family: var(--font-game); margin-bottom: 10px; }
        
        .card-duel { border-color: var(--neon-pink); box-shadow: 0 0 15px rgba(255, 0, 234, 0.1); }
        .card-duel:hover { box-shadow: 0 15px 30px rgba(255, 0, 234, 0.4); }
        .card-duel h2 { color: var(--neon-pink); font-family: var(--font-game); margin-bottom: 10px; }
        
        .card-laser { border-color: var(--neon-yellow); box-shadow: 0 0 15px rgba(255, 251, 0, 0.1); }
        .card-laser:hover { box-shadow: 0 15px 30px rgba(255, 251, 0, 0.4); }
        .card-laser h2 { color: var(--neon-yellow); font-family: var(--font-game); margin-bottom: 10px; }
        
        .card-tangent { border-color: var(--neon-purple); box-shadow: 0 0 15px rgba(176, 38, 255, 0.1); }
        .card-tangent:hover { box-shadow: 0 15px 30px rgba(176, 38, 255, 0.4); }
        .card-tangent h2 { color: var(--neon-purple); font-family: var(--font-game); margin-bottom: 10px; }
        
        .card-virus { border-color: var(--neon-orange); box-shadow: 0 0 15px rgba(255, 140, 0, 0.1); }
        .card-virus:hover { box-shadow: 0 15px 30px rgba(255, 140, 0, 0.4); }
        .card-virus h2 { color: var(--neon-orange); font-family: var(--font-game); margin-bottom: 10px; }

        /* --- GAME UI SPECIFIKT --- */
        .hud-header { 
            display: flex; 
            justify-content: space-between; 
            align-items: center;
            width: 100%; 
            max-width: 1000px; 
            font-family: var(--font-game); 
            font-size: 1.5rem; 
            margin-bottom: 1.5rem;
            background: rgba(0,0,0,0.5);
            padding: 15px 30px;
            border-radius: 15px;
            border: 1px solid rgba(255,255,255,0.1);
        }
        
        /* Sliders / Control Panel */
        .control-panel { 
            display: flex; 
            flex-direction: column; 
            gap: 20px; 
            width: 100%; 
            max-width: 400px; 
            background: var(--panel-bg); 
            padding: 2rem; 
            border-radius: 20px; 
            border: 1px solid rgba(255,255,255,0.1); 
            box-shadow: 0 10px 30px rgba(0,0,0,0.5);
        }
        .slider-group label { 
            display: flex; 
            justify-content: space-between; 
            font-weight: 600; 
            margin-bottom: 8px; 
            color: var(--text-muted); 
        }
        .slider-value {
            font-family: var(--font-math);
            color: white;
            background: rgba(0,0,0,0.5);
            padding: 2px 8px;
            border-radius: 5px;
        }
        input[type="range"] { 
            width: 100%; 
            height: 10px; 
            border-radius: 5px; 
            background: #1e293b; 
            appearance: none; 
            outline: none; 
        }
        input[type="range"]::-webkit-slider-thumb { 
            appearance: none; 
            width: 24px; 
            height: 24px; 
            border-radius: 50%; 
            background: white; 
            cursor: pointer; 
            border: 3px solid;
            transition: 0.1s;
        }
        input[type="range"]:active::-webkit-slider-thumb { transform: scale(1.2); }
        
        /* Specifikke farver til sliders */
        #hack-A::-webkit-slider-thumb { border-color: var(--neon-blue); box-shadow: 0 0 10px var(--neon-blue); }
        #hack-B::-webkit-slider-thumb { border-color: var(--neon-pink); box-shadow: 0 0 10px var(--neon-pink); }
        #hack-C::-webkit-slider-thumb { border-color: var(--neon-green); box-shadow: 0 0 10px var(--neon-green); }
        #virus-a::-webkit-slider-thumb { border-color: var(--neon-orange); box-shadow: 0 0 10px var(--neon-orange); }
        #virus-b::-webkit-slider-thumb { border-color: var(--neon-yellow); box-shadow: 0 0 10px var(--neon-yellow); }

        /* Matematik Displayboks */
        .math-hero {
            background: rgba(0,0,0,0.6); 
            padding: 1.5rem; 
            border-radius: 15px;
            font-family: var(--font-math); 
            font-size: 1.8rem; 
            text-align: center;
            border: 1px solid rgba(255,255,255,0.1); 
            margin: 1rem 0; 
            letter-spacing: 2px;
            box-shadow: inset 0 0 20px rgba(0,0,0,0.5);
        }

        /* 1v1 Split Screen (Shape Shifter) */
        .split-container { display: flex; width: 100%; max-width: 1200px; gap: 2rem; justify-content: center; }
        .player-zone { 
            flex: 1; 
            display: flex; 
            flex-direction: column; 
            align-items: center; 
            background: rgba(0,0,0,0.5); 
            padding: 2rem; 
            border-radius: 20px; 
            border: 2px solid; 
        }
        .zone-p1 { border-color: var(--neon-blue); box-shadow: inset 0 0 50px rgba(0, 243, 255, 0.05); }
        .zone-p2 { border-color: var(--neon-pink); box-shadow: inset 0 0 50px rgba(255, 0, 234, 0.05); }
        
        .key-hint { 
            display: inline-block; 
            background: rgba(255,255,255,0.1); 
            color: white;
            padding: 4px 8px; 
            border-radius: 6px; 
            font-family: var(--font-game); 
            font-size: 0.9rem;
            margin: 0 2px; 
            border: 1px solid rgba(255,255,255,0.3); 
        }

        /* Winner Overlay */
        .game-overlay { 
            position: absolute; 
            top:0; left:0; width:100%; height:100%; 
            background:rgba(0,0,0,0.95); 
            z-index: 2000; 
            display:flex; 
            flex-direction:column; 
            align-items:center; 
            justify-content:center; 
            backdrop-filter: blur(10px);
        }

        /* Utils */
        .flex-row { display: flex; gap: 2rem; width: 100%; max-width: 1000px; justify-content: center; align-items: flex-start; }
        .text-green { color: var(--neon-green); text-shadow: 0 0 10px var(--neon-green); }
        .text-red { color: var(--neon-red); text-shadow: 0 0 10px var(--neon-red); }

        @media (max-width: 1000px) {
            .flex-row, .split-container { flex-direction: column; align-items: center; }
            .title-glow { font-size: 3rem; }
            canvas { max-width: 100%; height: auto; }
        }
    </style>
</head>
<body>

    <!-- ==================== HOVEDMENU ==================== -->
    <div id="screen-menu" class="screen active">
        <a href="MAT-MUN-Index.html" class="back-btn">⬅ Tilbage til Noter</a>
        <h1 class="title-glow">MATHEMASTER<br>ARCADE</h1>
        <p class="subtitle">Slip matematikken fri! Vælg et spil herunder for at træne dine færdigheder til B-Niveau eksamen i en visuel og interaktiv spillehal.</p>
        
        <div class="mode-cards">
            <!-- 1. Parabel Hacker -->
            <div class="card card-solo" onclick="showScreen('screen-hacker-setup')">
                <div class="card-icon">🔧</div>
                <div>
                    <h2>PARABEL HACKER</h2>
                    <p>Andengradspolynomier (Solo). Brug sliders til at forme funktionen, der overlapper målet. Spil mod uret!</p>
                </div>
            </div>
            
            <!-- 2. Shape Shifter -->
            <div class="card card-duel" onclick="showScreen('screen-duel-setup')">
                <div class="card-icon">⚔️</div>
                <div>
                    <h2>SHAPE SHIFTER</h2>
                    <p>Andengradspolynomier (1v1). Bøj parabler i realtime med tastaturet. Først til at matche "Target Grafen" vinder!</p>
                </div>
            </div>

            <!-- 3. Laser Skjoldet -->
            <div class="card card-laser" onclick="showScreen('screen-laser-setup')">
                <div class="card-icon">🛡️</div>
                <div>
                    <h2>LASER SKJOLDET</h2>
                    <p>Analytisk Geometri. Placer dit skjold præcist ud fra afstandsformlen for at blokere de dødelige lasere!</p>
                </div>
            </div>

            <!-- 4. Tangent Sniper -->
            <div class="card card-tangent" onclick="showScreen('screen-tangent-setup')">
                <div class="card-icon">🎯</div>
                <div>
                    <h2>TANGENT SNIPER</h2>
                    <p>Differentialregning (1v1). Kør på landskabet. Kanonen peger langs tangenten ($f'(x)$). Find hældningen og skyd!</p>
                </div>
            </div>

            <!-- 5. Virus Outbreak -->
            <div class="card card-virus" onclick="showScreen('screen-virus-setup')">
                <div class="card-icon">🦠</div>
                <div>
                    <h2>VIRUS OUTBREAK</h2>
                    <p>Eksponentiel Vækst. Aflæs "Intel", og juster $b$ og $a$ for at skabe en kurve, der kurerer virussen før det er for sent!</p>
                </div>
            </div>
        </div>
    </div>


    <!-- ==================== SPIL 1: PARABEL HACKER ==================== -->
    <div id="screen-hacker-setup" class="screen">
        <button class="back-btn" onclick="showScreen('screen-menu')">⬅ Menu</button>
        <h2 class="title-glow" style="font-size: 3rem; color: var(--neon-blue); text-shadow: 0 0 20px var(--neon-blue);">PARABEL HACKER</h2>
        <p class="subtitle">Den hvide stiplede linje er fjendens signal. Dit mål er at justere A, B og C, indtil din blå parabel overlapper den perfekt. Hver gang du hacker systemet, får du +10 sekunder.</p>
        <button class="btn-neon btn-blue" onclick="startHackerGame()">START HACK</button>
    </div>

    <div id="screen-hacker-game" class="screen">
        <button class="back-btn" onclick="endHackerGame()">⬅ Afbryd Hack</button>
        
        <div class="hud-header" style="border-color: var(--neon-blue);">
            <span style="color: var(--neon-blue);">SUCCESFULDE HACKS: <span id="hack-score" style="color:white; font-size:2rem;">0</span></span>
            <span style="color: var(--neon-pink);">TID: <span id="hack-time" style="color:white; font-size:2rem;">60</span>s</span>
        </div>
        
        <div class="flex-row">
            <canvas id="hackCanvas" width="500" height="500"></canvas>
            
            <div class="control-panel" style="border-color: var(--neon-blue);">
                <h3 style="text-align: center; font-family: var(--font-game); color: var(--neon-blue); margin-bottom: 20px;">TUNING SYSTEM</h3>
                
                <div class="math-hero" id="hack-formula" style="font-size: 1.4rem;">
                    $f(x) = 1x^2 + 0x + 0$
                </div>

                <div class="slider-group">
                    <label><span>Konstant A (Krumning)</span> <span class="slider-value" id="valH-A">1.0</span></label>
                    <input type="range" id="hack-A" min="-3" max="3" step="0.1" value="1" oninput="updateHacker()">
                </div>
                <div class="slider-group">
                    <label><span>Konstant B (Forskydning)</span> <span class="slider-value" id="valH-B">0.0</span></label>
                    <input type="range" id="hack-B" min="-6" max="6" step="0.5" value="0" oninput="updateHacker()">
                </div>
                <div class="slider-group">
                    <label><span>Konstant C (Skæring Y)</span> <span class="slider-value" id="valH-C">0.0</span></label>
                    <input type="range" id="hack-C" min="-8" max="8" step="1" value="0" oninput="updateHacker()">
                </div>
                
                <div id="hack-status" style="text-align: center; font-size: 1.5rem; font-family: var(--font-game); margin-top: 15px; color: var(--neon-red); text-shadow: 0 0 10px var(--neon-red);">SIGNAL UDE AF SINK</div>
            </div>
        </div>
    </div>

    <div id="screen-hacker-end" class="screen">
        <h2 class="title-glow" style="color: var(--neon-red); text-shadow: 0 0 30px var(--neon-red);">SYSTEM LUKKET</h2>
        <p style="font-size: 1.5rem; margin-bottom: 2rem;">Færdige Hacks: <span id="hack-final-score" style="color: var(--neon-blue); font-weight: bold; font-size: 3rem;">0</span></p>
        <button class="btn-neon btn-blue" onclick="startHackerGame()">HACK IGEN</button>
        <button class="btn-neon btn-pink" onclick="showScreen('screen-menu')">HOVEDMENU</button>
    </div>


    <!-- ==================== SPIL 2: SHAPE SHIFTER DUEL ==================== -->
    <div id="screen-duel-setup" class="screen">
        <button class="back-btn" onclick="showScreen('screen-menu')">⬅ Menu</button>
        <h2 class="title-glow" style="font-size: 3rem; color: var(--neon-pink); text-shadow: 0 0 20px var(--neon-pink);">SHAPE SHIFTER (1v1)</h2>
        <p class="subtitle">Byg grafen hurtigere end din modstander! Først til 5 point.</p>
        
        <div style="background: rgba(0,0,0,0.5); padding: 2rem; border-radius: 15px; border: 1px solid rgba(255,255,255,0.2); max-width: 600px; text-align: center; margin-bottom: 2rem;">
            <div style="display: flex; justify-content: space-around;">
                <div style="color: var(--neon-blue);">
                    <h3 style="margin-bottom: 15px; font-family: var(--font-game);">SPILLER 1 (BLÅ)</h3>
                    <p><span class="key-hint">W</span> <span class="key-hint">S</span> ændrer <b>a</b></p>
                    <p style="margin-top: 10px;"><span class="key-hint">A</span> <span class="key-hint">D</span> ændrer <b>c</b></p>
                </div>
                <div style="color: var(--neon-pink);">
                    <h3 style="margin-bottom: 15px; font-family: var(--font-game);">SPILLER 2 (PINK)</h3>
                    <p><span class="key-hint">↑</span> <span class="key-hint">↓</span> ændrer <b>a</b></p>
                    <p style="margin-top: 10px;"><span class="key-hint">←</span> <span class="key-hint">→</span> ændrer <b>c</b></p>
                </div>
            </div>
        </div>
        <button class="btn-neon btn-pink" onclick="startDuelGame()">START DUEL</button>
    </div>

    <div id="screen-duel-game" class="screen">
        <button class="back-btn" onclick="endDuelGame()">⬅ Afslut Duel</button>
        
        <div class="hud-header" style="border-color: var(--neon-pink);">
            <span style="color: var(--neon-blue);">P1: <span id="d-score-1" style="color:white; font-size:2rem;">0</span></span>
            <span style="font-family: var(--font-game); font-size: 2rem;">MÅL GRAFEN</span>
            <span style="color: var(--neon-pink);">P2: <span id="d-score-2" style="color:white; font-size:2rem;">0</span></span>
        </div>

        <div class="split-container">
            <!-- Player 1 -->
            <div class="player-zone zone-p1">
                <h3 style="color: var(--neon-blue); font-family: var(--font-game); margin-bottom: 15px;">SPILLER 1</h3>
                <canvas id="duelCanvas1" width="400" height="400"></canvas>
                <div class="math-hero" style="width: 100%; padding: 10px; margin-top: 15px; border-color: var(--neon-blue);">
                    $f(x) = $<span id="d1-a" style="color:var(--neon-blue)">1</span>$x^2 + $<span id="d1-c" style="color:var(--neon-blue)">0</span>
                </div>
            </div>
            
            <!-- Player 2 -->
            <div class="player-zone zone-p2">
                <h3 style="color: var(--neon-pink); font-family: var(--font-game); margin-bottom: 15px;">SPILLER 2</h3>
                <canvas id="duelCanvas2" width="400" height="400"></canvas>
                <div class="math-hero" style="width: 100%; padding: 10px; margin-top: 15px; border-color: var(--neon-pink);">
                    $f(x) = $<span id="d2-a" style="color:var(--neon-pink)">1</span>$x^2 + $<span id="d2-c" style="color:var(--neon-pink)">0</span>
                </div>
            </div>
        </div>

        <!-- Vinder Overlay -->
